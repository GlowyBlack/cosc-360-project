+            $group: {
+                _id: "$requestId",
+                lastContent: { $first: "$content" },
+                lastCreatedAt: { $first: "$createdAt" },
+                unreadCount: { $sum: { $cond: [isUnreadIncoming, 1, 0] } },
+            },
+        };
+
+        return Message.aggregate([inTheseRequests, newestFirst, oneRowPerRequest]);
